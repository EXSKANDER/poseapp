{
  "expo": {
    "name": "PoseApp",
    "slug": "PoseApp",
    "version": "1.0.0",
    "description": "A mobile figure drawing practice tool with 3D pose models, timed sessions, and a curated pose library for artists.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "poseapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.poseapp.app",
      "infoPlist": {
        "MinimumOSVersion": "15.0",
        "NSUserNotificationsUsageDescription": "PoseApp sends practice reminders to help you maintain your drawing streak."
      }
    },
    "android": {
      "package": "com.poseapp.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["RECEIVE_BOOT_COMPLETED", "VIBRATE", "WAKE_LOCK", "SCHEDULE_EXACT_ALARM"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a7ea4",
          "dark": {
            "backgroundColor": "#151718",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/splash-icon.png",
          "color": "#0a7ea4",
          "defaultChannel": "practice-reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbc3e097-baab-4183-bf77-45603338e996"
      }
    }
  }
}
